---
import Default from "@astrojs/starlight/components/Footer.astro";

// Localized strings for the custom footer, keyed by the page language
// (Starlight sets `lang` on the route data; the root locale is English).
const FOOTER_STRINGS: Record<
	string,
	{ builtWith: string; poweredBy: string; license: string }
> = {
	en: {
		builtWith: "Built with",
		poweredBy: "Powered by",
		license: "MIT License",
	},
	es: {
		builtWith: "Creado con",
		poweredBy: "Impulsado por",
		license: "Licencia MIT",
	},
};

const lang = Astro.locals.starlightRoute?.lang ?? "en";
const t = FOOTER_STRINGS[lang] ?? FOOTER_STRINGS.en;
---

<Default {...Astro.props}><slot /></Default>

<div class="custom-footer">
	<div class="footer-inner">
		<p>
			{t.builtWith}
			<a
				href="https://starlight.astro.build/"
				target="_blank"
				rel="external noopener noreferrer">Starlight</a
			>
			&middot; {t.poweredBy}
			<a
				href="https://www.crowdsec.net/"
				target="_blank"
				rel="external noopener noreferrer">CrowdSec</a
			>
		</p>
		<p class="footer-links">
			<a
				href="https://github.com/jmrplens/cs-routeros-bouncer"
				target="_blank"
				rel="external noopener noreferrer">GitHub</a
			>
			<span aria-hidden="true">&middot;</span>
			<a
				href="https://github.com/jmrplens/cs-routeros-bouncer/issues"
				target="_blank"
				rel="external noopener noreferrer">Issues</a
			>
			<span aria-hidden="true">&middot;</span>
			<a
				href="https://github.com/jmrplens/cs-routeros-bouncer/blob/main/LICENSE"
				target="_blank"
				rel="external noopener noreferrer">{t.license}</a
			>
		</p>
	</div>
</div>

<style>
	.custom-footer {
		border-top: 1px solid var(--sl-color-gray-5);
		padding: 1.5rem 1rem;
		text-align: center;
		font-size: var(--sl-text-xs);
		color: var(--sl-color-gray-3);
	}
	.footer-inner {
		max-width: 72rem;
		margin: 0 auto;
	}
	.custom-footer a {
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}
	.custom-footer a:hover {
		text-decoration: underline;
	}
	.footer-links {
		margin-top: 0.5rem;
	}
</style>
