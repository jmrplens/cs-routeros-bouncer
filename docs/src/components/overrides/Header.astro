---
/**
 * Custom Header override: wraps Starlight's default Header
 * and prepends an announcement/info banner.
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Header.astro';
---

<div class="announcement-bar" role="banner" aria-label="Project announcement">
  <p>
    <strong>cs-routeros-bouncer</strong> — Protect your MikroTik router with
    <a href="https://www.crowdsec.net/" rel="noopener noreferrer">CrowdSec</a> threat intelligence
  </p>
</div>

<Default {...Astro.props}><slot /></Default>

<style>
  .announcement-bar {
    background: linear-gradient(90deg, rgb(var(--sl-color-accent)), rgb(63, 81, 181));
    color: #fff;
    text-align: center;
    padding: 0.375rem 1rem;
    font-size: 0.8rem;
    line-height: 1.4;
  }
  .announcement-bar p {
    margin: 0;
  }
  .announcement-bar a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .announcement-bar a:hover {
    opacity: 0.85;
  }

  @media print {
    .announcement-bar {
      display: none;
    }
  }
</style>
