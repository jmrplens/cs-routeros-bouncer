{
    "name": "docs",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "dev": "astro dev",
        "start": "astro dev",
        "analyze": "pnpm run check && pnpm run lint && pnpm run format:check && pnpm run build && pnpm run html:validate",
        "lint": "eslint .",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "html:validate": "html-validate \"dist/**/*.html\"",
        "check": "astro check",
        "build": "astro build",
        "preview": "astro preview",
        "astro": "astro",
        "postinstall": "npx playwright install --with-deps chromium"
    },
    "dependencies": {
        "@astrojs/starlight": "^0.39.0",
        "astro": "^6.3.0",
        "playwright": "^1.59.1",
        "rehype-mermaid": "^3.0.0",
        "sharp": "^0.34.5"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.9",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.3.0",
        "eslint-plugin-astro": "^1.7.0",
        "globals": "^17.6.0",
        "html-validate": "^10.15.0",
        "prettier": "^3.8.3",
        "prettier-plugin-astro": "^0.14.1",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.2"
    }
}
