{
  "name": "docs",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "analyze": "pnpm run check && pnpm run lint && pnpm run format:check && pnpm run build && pnpm run html:validate",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "html:validate": "test -n \"$(find dist -name '*.html' -print -quit 2>/dev/null)\" || { echo 'No HTML files found in docs/dist. Run pnpm build first.' >&2; exit 1; }; html-validate --max-warnings 0 \"dist/**/*.html\"",
    "check": "astro check",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "playwright:install": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.40.0",
    "astro": "^7.0.3",
    "rehype-mermaid": "^3.0.0",
    "sharp": "^0.35.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-plugin-astro": "^2.1.1",
    "globals": "^17.6.0",
    "html-validate": "^11.5.3",
    "markdownlint-cli2": "0.22.1",
    "playwright": "^1.61.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  }
}
