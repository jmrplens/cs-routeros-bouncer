# =============================================================================
# Functional Test Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# These tests run against REAL hardware — use a dedicated test router or
# ensure no production traffic depends on the address lists being modified.
# =============================================================================

# --- MikroTik RouterOS API ---------------------------------------------------
# Address in host:port format (API port, NOT HTTP).
MIKROTIK_HOST=192.168.0.1:8728
MIKROTIK_USER=crowdsec
MIKROTIK_PASS=your-password-here
# TLS settings (optional, default false)
MIKROTIK_TLS=false
MIKROTIK_TLS_INSECURE=false

# --- MikroTik SSH (for out-of-band verification) ----------------------------
# Used to verify router state independently of the API under test.
MIKROTIK_SSH_HOST=192.168.0.1
MIKROTIK_SSH_PORT=22
MIKROTIK_SSH_USER=admin
# SSH private key (optional — omit or leave empty if the router uses password auth
# or the default SSH key is already configured in ~/.ssh/).
# MIKROTIK_SSH_KEY=~/.ssh/id_rsa

# --- CrowdSec LAPI -----------------------------------------------------------
CROWDSEC_URL=http://localhost:8080/
CROWDSEC_BOUNCER_API_KEY=your-bouncer-api-key-here

# --- Bouncer binary & config ------------------------------------------------
# Path to the compiled bouncer binary (for service-level tests).
BOUNCER_BIN=/opt/cs-routeros-bouncer/bin/cs-routeros-bouncer
# Path to the bouncer config file used during tests.
BOUNCER_CONFIG=/etc/cs-routeros-bouncer/config.yaml

# --- Test behaviour ----------------------------------------------------------
# Address list names used for testing (isolated from production lists).
TEST_IPV4_LIST=crowdsec-banned
TEST_IPV6_LIST=crowdsec6-banned
# Comment prefix used by the bouncer.
TEST_COMMENT_PREFIX=crowdsec-bouncer
# Maximum acceptable CPU percentage during reconciliation (default 30).
TEST_CPU_THRESHOLD=30
# SNMP community string for CPU/memory monitoring (default: public).
# Only requires read access — the tests never write via SNMP.
#
# RouterOS setup (run on the MikroTik terminal):
#   /snmp set enabled=yes trap-version=2
#   /snmp community set [find name=public] read-access=yes write-access=no security=none addresses=0.0.0.0/0,::/0
#
# To restrict SNMP to your LAN only (recommended):
#   /snmp community set [find name=public] addresses=192.168.0.0/24
#
SNMP_COMMUNITY=public
# Number of CPU cores on the MikroTik device (default: 4).
# RB5009 = 4, hAP ax³ = 4, CCR2004 = 4, CCR2116 = 16, hEX = 2, etc.
MIKROTIK_CPU_CORES=4
